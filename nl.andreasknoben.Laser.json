{
    "id" : "nl.andreasknoben.Laser",
    "runtime" : "org.gnome.Platform",
    "runtime-version" : "50",
    "sdk" : "org.gnome.Sdk",
    "command" : "laser",
    "finish-args" : [
        "--share=network",
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--device=all",
        "--talk-name=org.gtk.vfs.*",
        "--filesystem=xdg-run/gvfsd"
    ],
    "cleanup" : [
        "/include",
        "/lib/pkgconfig",
        "/man",
        "/share/doc",
        "/share/gtk-doc",
        "/share/man",
        "/share/pkgconfig",
        "*.la",
        "*.a"
    ],
    "modules" : [
        {
            "name" : "libcdio",
            "buildsystem" : "autotools",
            "config-opts" : [
                "--disable-static",
                "--enable-shared",
                "--enable-cdio-paranoia"
            ],
            "sources" : [
                {
                    "type" : "archive",
                    "url" : "https://github.com/libcdio/libcdio/releases/download/2.3.0/libcdio-2.3.0.tar.gz",
                    "sha256" : "37bcb13296febbcff9dc4485834bac09212cb463c31fcea52f70ee1dd3a5a5de"
                }
            ]
        },
        {
            "name" : "libcdio-paranoia",
            "buildsystem" : "autotools",
            "config-opts" : [
                "--disable-static",
                "--enable-shared"
            ],
            "sources" : [
                {
                    "type" : "archive",
                    "url" : "https://github.com/libcdio/libcdio-paranoia/releases/download/release-10.2+2.0.2/libcdio-paranoia-10.2+2.0.2.tar.gz",
                    "sha256" : "99488b8b678f497cb2e2f4a1a9ab4a6329c7e2537a366d5e4fef47df52907ff6"
                }
            ]
        },
        {
            "name" : "gst-plugins-ugly",
            "buildsystem" : "meson",
            "config-opts" : [
                "-Dcdio=enabled",
                "-Dsidplay=disabled",
                "-Dmpeg2dec=disabled",
                "-Ddvdlpcmdec=disabled",
                "-Da52dec=disabled",
                "-Drealmedia=disabled",
                "-Ddoc=disabled",
                "-Dgpl=enabled"
            ],
            "sources" : [
                {
                    "type" : "archive",
                    "url" : "https://gstreamer.freedesktop.org/src/gst-plugins-ugly/gst-plugins-ugly-1.26.11.tar.xz",
                    "sha256" : "bf9c9f72ee374825cfd43868c285bcb01700df2584069e75d7af455fe48244f8"
                }
            ]
        },
        {
            "name" : "libdiscid",
            "sources" : [
                {
                    "type" : "archive",
                    "url" : "https://github.com/metabrainz/libdiscid/releases/download/v0.6.5/libdiscid-0.6.5.tar.gz",
                    "sha256" : "72dbb493e07336418fe2056f0ebc7ce544eedb500bb896cc1cc04bd078c2d530"
                }
            ]
        },
        {
            "name" : "cd-discid",
            "buildsystem" : "simple",
            "build-commands" : [
                "make",
                "make install PREFIX=/app"
            ],
            "sources" : [
                {
                    "type" : "archive",
                    "url" : "https://github.com/taem/cd-discid/archive/refs/tags/1.4.tar.gz",
                    "sha256" : "6f07df25ebf17b8336c17a50092ed288cc5a6b86f85705db7e1aa35ba26683cf"
                }
            ]
        },
        {
			"name": "python3-modules",
			"buildsystem": "simple",
			"build-commands": [],
			"modules": [
				{
				    "name": "python3-discid",
				    "buildsystem": "simple",
				    "build-commands": [
				        "pip3 install --verbose --exists-action=i --no-index --find-links=\"file://${PWD}\" --prefix=${FLATPAK_DEST} \"discid\" --no-build-isolation"
				    ],
				    "sources": [
				        {
				            "type": "file",
				            "url": "https://files.pythonhosted.org/packages/29/64/ca6cb42642108af91af780913b97765c9ef0c19c7e603b1eb50746659780/discid-1.4.0.tar.gz",
				            "sha256": "50fd3db445caeb44b9f7763777ed49688c3cf4633da99d340c25b919496ba8b5"
				        }
				    ]
				},
				{
				    "name": "python3-musicbrainzngs",
				    "buildsystem": "simple",
				    "build-commands": [
				        "pip3 install --verbose --exists-action=i --no-index --find-links=\"file://${PWD}\" --prefix=${FLATPAK_DEST} \"musicbrainzngs\" --no-build-isolation"
				    ],
				    "sources": [
				        {
				            "type": "file",
				            "url": "https://files.pythonhosted.org/packages/6d/fd/cef7b2580436910ccd2f8d3deec0f3c81743e15c0eb5b97dde3fbf33c0c8/musicbrainzngs-0.7.1-py2.py3-none-any.whl",
				            "sha256": "e841a8f975104c0a72290b09f59326050194081a5ae62ee512f41915090e1a10"
				        }
				    ]
				}
			]
		},
        {
            "name" : "laser",
            "buildsystem" : "meson",
            "sources" : [
                {
                    "type" : "archive",
                    "url": "https://codeberg.org/andreasknoben/Laser/archive/v0.3.1.tar.gz",
                    "sha256": "3df5ab92b33e7ad4734680d75c147ebba51ab0cdcdbea3988724747cb55e9ff8"
                }
            ]
        }
    ]
}
